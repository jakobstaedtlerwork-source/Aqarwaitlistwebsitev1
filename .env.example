# Database
# On Mac with Homebrew Postgres, use your macOS username (no password):
# DATABASE_URL="postgresql://yourusername@localhost:5432/aqar?schema=public"
# On Linux or Docker, typically:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aqar?schema=public"

# Auth.js
AUTH_SECRET="generate-a-random-secret-here"
# Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend) - Optional, logs to console if not set
# RESEND_API_KEY="re_..."
# EMAIL_FROM="noreply@yourdomain.com"

# Social Login - Optional
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."
# APPLE_ID="..."
# APPLE_SECRET="..."

# File Storage - Optional, uses local /uploads if not set
# S3_BUCKET="your-bucket"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_ENDPOINT="https://your-r2-endpoint.r2.cloudflarestorage.com"  # For Cloudflare R2

# Upload limit (bytes) - Default: 10MB
# MAX_FILE_SIZE="10485760"

# Demo Credentials (after running: npx prisma db seed)
# Landlord: demo@aqar.dev / demo1234
# Tenant:   tenant@aqar.dev / demo1234
